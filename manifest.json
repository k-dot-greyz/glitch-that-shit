{
  "manifest_version": 3,
  "name": "zenOS: glitch-that-shit",
  "version": "0.2.0",
  "description": "Personal reality distortion field. OKLCH a11y engine, HDR chroma clamping, sensory mode enforcement. zenOS-powered.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "index.html",
    "default_title": "glitch-that-shit"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
