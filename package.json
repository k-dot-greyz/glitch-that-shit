{
  "name": "glitch-that-shit",
  "version": "0.1.0",
  "description": "A browser extension that glitches out unwanted words, phrases, or ads with custom visual effects",
  "main": "index.js",
  "scripts": {
    "setup": "node scripts/setup.js",
    "validate": "node scripts/setup.js --validate-only",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "dev:firefox": "web-ext run --source-dir=. --verbose",
    "dev:chrome": "echo 'Load extension manually in chrome://extensions/'",
    "package:firefox": "web-ext build --source-dir=. --artifacts-dir=dist",
    "package:chrome": "node scripts/package-chrome.js",
    "clean": "rimraf dist node_modules package-lock.json",
    "precommit": "npm run lint && npm run format:check && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-dot-greyz/glitch-that-shit.git"
  },
  "keywords": [
    "browser-extension",
    "content-filter",
    "glitch-effect",
    "privacy",
    "ad-blocker",
    "zenOS"
  ],
  "author": "k-dot-greyz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/k-dot-greyz/glitch-that-shit/issues"
  },
  "homepage": "https://github.com/k-dot-greyz/glitch-that-shit#readme",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "web-ext": "^7.11.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base"
    ],
    "env": {
      "browser": true,
      "webextensions": true,
      "es2021": true,
      "jest": true
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  }
}

